      "html": "\n<div class=\"w-full bg-white\" data-kid=\"0\">\n    <section class=\"relative w-full h-[850px] bg-[#074643] overflow-hidden flex items-center\" style=\"clip-path: url(#hero-wave-clip);\" data-kid=\"1\">\n        <style data-kid=\"2\">\n            @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Train+One&display=swap');\n            \n            .font-train {\n                font-family: 'Train One', system-ui;\n                letter-spacing: 0.15em;\n            }\n            .font-inter {\n                font-family: 'Inter', sans-serif;\n            }\n        </style>\n\n        \n        <svg width=\"0\" height=\"0\" class=\"absolute\" data-kid=\"3\">\n            <defs data-kid=\"4\">\n                <clipPath id=\"hero-wave-clip\" clipPathUnits=\"objectBoundingBox\" data-kid=\"5\">\n                    <path d=\"M0,0 L1,0 L1,0.82 C0.8,0.75 0.6,0.9 0.4,0.85 C0.2,0.8 0,0.9 0,0.95 Z\" data-kid=\"6\"></path>\n                </clipPath>\n            </defs>\n        </svg>\n\n        <div class=\"container mx-auto px-10 lg:px-24 flex flex-col lg:flex-row items-center justify-between h-full relative z-10 pt-8\" data-kid=\"7\">\n            \n            <div class=\"w-full lg:w-[45%] text-white flex flex-col items-start pt-4\" data-kid=\"8\">\n                <div class=\"mb-5\" data-kid=\"9\">\n                    <span class=\"font-train text-3xl lg:text-[42px] uppercase leading-none text-white tracking-[0.2em]\" data-kid=\"10\">HELLO I AM</span>\n                </div>\n                \n                <h1 class=\"font-inter font-bold text-7xl lg:text-[104px] mb-8 leading-[0.9] tracking-tight\" data-kid=\"11\">\n                    Lorehm<br data-kid=\"12\">ipsum\n                </h1>\n                \n                <p class=\"font-inter text-xl lg:text-[25px] text-white/80 max-w-[420px] mb-14 leading-relaxed font-normal\" data-kid=\"13\">\n                    Lorem ipsum dolor sit amet consectetur. Mollis feugiat.\n                </p>\n                \n                <div class=\"flex items-center gap-10\" data-kid=\"14\">\n                    <button class=\"bg-[#111111] hover:bg-black text-white px-10 py-4.5 rounded-full font-inter font-bold text-[12px] tracking-widest transition-all shadow-xl uppercase border border-white/5\" data-kid=\"15\">\n                        START CONSULTING\n                    </button>\n                    \n                    <div class=\"flex items-center gap-3\" data-kid=\"16\">\n                        <div class=\"w-2.5 h-2.5 rounded-full bg-[#1ed760] shadow-[0_0_10px_rgba(30,215,96,0.5)]\" data-kid=\"17\"></div>\n                        <p class=\"font-inter text-white font-semibold text-[15px]\" data-kid=\"18\">\n                            Lorem ipsum dolor sit\n                        </p>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"w-full lg:w-[55%] flex justify-end items-center relative h-full\" data-kid=\"19\">\n                <div class=\"relative\" data-kid=\"20\">\n                    \n                    <div class=\"w-[450px] h-[450px] lg:w-[620px] lg:h-[620px] rounded-full overflow-hidden flex items-center justify-center shadow-2xl\" data-kid=\"21\">\n                        <img src=\"https://images.unsplash.com/photo-1600804889194-e6fbf08ddb39?auto=format&fit=crop&q=80&w=1000\" alt=\"Portrait\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n                    </div>\n                    \n                    \n                    <div class=\"absolute left-[-10px] lg:left-[8%] bottom-[22%] bg-white rounded-[42px] p-10 lg:p-12 shadow-[0_30px_70px_rgba(0,0,0,0.25)] w-52 lg:w-60 flex flex-col items-start justify-center z-20\" data-kid=\"23\">\n                        <span class=\"font-inter font-black text-[64px] text-black mb-0 leading-none tracking-tighter\" data-kid=\"24\">10