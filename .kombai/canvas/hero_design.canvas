      "html": "\n<section class=\"relative w-full h-[780px] bg-[#022c22] overflow-hidden flex items-center justify-center font-['Outfit']\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Syne:wght@400;700;800&display=swap');\n\n        .font-syne { font-family: 'Syne', sans-serif; }\n        \n        .geometric-bg {\n            clip-path: polygon(40% 0%, 100% 0%, 100% 100%, 0% 100%);\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0) rotate(0deg); }\n            50% { transform: translateY(-20px) rotate(2deg); }\n        }\n\n        .animate-float-slow {\n            animation: float 6s ease-in-out infinite;\n        }\n\n        .cta-hover:hover .cta-arrow {\n            transform: translateX(5px);\n        }\n\n        /* Outline text utility */\n        .text-outline {\n            -webkit-text-stroke: 2px rgba(255, 255, 255, 0.5);\n            color: transparent;\n        }\n    </style>\n\n    \n    <div class=\"absolute inset-0 z-0\" data-kid=\"2\">\n        \n        <div class=\"absolute right-0 top-0 w-1/2 h-full bg-slate-50 geometric-bg opacity-100\" data-kid=\"3\"></div>\n        \n        <div class=\"absolute right-[-10%] top-0 w-1/3 h-full bg-emerald-900/20 transform skew-x-12\" data-kid=\"4\"></div>\n    </div>\n\n    \n    <div class=\"relative z-10 w-full max-w-7xl px-8 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center\" data-kid=\"5\">\n        \n        \n        <div class=\"flex flex-col space-y-12\" data-kid=\"6\">\n            <div class=\"space-y-8\" data-kid=\"7\">\n                <div class=\"flex items-center space-x-4\" data-kid=\"8\">\n                    <span class=\"w-12 h-[2px] bg-emerald-500 rounded-full\" data-kid=\"9\"></span>\n                    <span class=\"text-emerald-500 text-xs font-black tracking-[0.5em] uppercase\" data-kid=\"10\">Digital Alchemist</span>\n                </div>\n                \n                <h1 class=\"font-syne text-[84px] md:text-[110px] font-extrabold text-white leading-[0.85] tracking-tighter\" data-kid=\"11\">\n                    Lorehm <br data-kid=\"12\">\n                    <span class=\"text-outline\" data-kid=\"13\">Ipsum</span>\n                </h1>\n                \n                <p class=\"text-white/60 text-lg md:text-xl max-w-sm leading-relaxed font-normal\" data-kid=\"14\">\n                    Crafting minimalist visual systems and geometric identities for the next generation of digital-first brands.\n                </p>\n            </div>\n\n            <div class=\"flex flex-col sm:flex-row items-start sm:items-center gap-8\" data-kid=\"15\">\n                <button class=\"cta-hover group relative overflow-hidden bg-emerald-500 text-[#022c22] px-10 py-5 rounded-full font-bold text-sm tracking-widest uppercase transition-all duration-500 hover:bg-white hover:scale-105 shadow-[0_20px_50px_rgba(16,185,129,0.3)] active:scale-95 flex items-center gap-3\" data-kid=\"16\">\n                    Start Consulting\n                    <svg class=\"cta-arrow w-5 h-5 transition-transform duration-300\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"17\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\" data-kid=\"18\"></path>\n                    </svg>\n                </button>\n                \n                <div class=\"flex items-center gap-4\" data-kid=\"19\">\n                    <div class=\"relative\" data-kid=\"20\">\n                        <span class=\"block w-3 h-3 rounded-full bg-emerald-400\" data-kid=\"21\"></span>\n                        <span class=\"absolute inset-0 w-3 h-3 rounded-full bg-emerald-400 animate-ping opacity-75\" data-kid=\"22\"></span>\n                    </div>\n                    <p class=\"text-white/40 text-sm font-medium tracking-wide\" data-kid=\"23\">AVAILABLE FOR PROJECTS</p>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"relative flex justify-center lg:justify-end\" data-kid=\"24\">\n            \n            <div class=\"relative group\" data-kid=\"25\">\n                \n                <div class=\"absolute -inset-6 border-2 border-emerald-500/20 rounded-full scale-105 group-hover:scale-110 transition-transform duration-700\" data-kid=\"26\"></div>\n                <div class=\"absolute -inset-12 border border-emerald-500/5 rounded-full scale-110 group-hover:scale-115 transition-transform duration-1000\" data-kid=\"27\"></div>\n                \n                <div class=\"relative w-[500px] h-[500px] rounded-full overflow-hidden border-[18px] border-[#022c22] shadow-[0_40px_100px_rgba(0,0,0,0.4)] z-10 bg-emerald-900/50\" data-kid=\"28\">\n                    <img src=\"https://i.pravatar.cc/1000?u=fashion_designer\" alt=\"Lorehm Ipsum\" class=\"w-full h-full object-cover scale-110 group-hover:scale-105 transition-transform duration-1000 ease-out grayscale group-hover:grayscale-0\" decoding=\"async\" data-kid=\"29\">\n                </div>\n\n                \n                <div class=\"animate-float-slow absolute -left-28 bottom-2 z-30 bg-white/95 backdrop-blur-lg p-10 rounded-[44px] shadow-[0_50px_100px_rgba(0,0,0,0.25)] border border-white/60 flex flex-col items-center justify-center min-w-[210px] transform hover:scale-105 transition-all duration-500\" data-kid=\"30\">\n                    <span class=\"text-[#022c22] text-[80px] font-extrabold font-syne leading-none tracking-tighter\" data-kid=\"31\">10K</span>\n                    <p class=\"text-emerald-900/60 text-[11px] font-black tracking-[0.4em] uppercase mt-4 text-center\" data-kid=\"32\">Design <br data-kid=\"33\"> Milestone</p>\n                </div>\n\n                \n                <div class=\"absolute -right-6 top-1/3 w-6 h-6 bg-emerald-400 rounded-full z-20 blur-[2px] animate-pulse opacity-80 shadow-[0_0_20px_rgba(52,211,153,0.6)]\" data-kid=\"34\"></div>\n            </div>\n        </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-12 left-12 flex space-x-8 z-20\" data-kid=\"35\">\n        <a href=\"#\" class=\"text-white/40 hover:text-emerald-400 transition-all duration-300 text-[10px] font-black tracking-[0.4em] uppercase group flex items-center gap-2\" data-kid=\"36\">\n            <span class=\"w-1.5 h-1.5 bg-emerald-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"37\"></span>\n            Instagram\n        </a>\n        <a href=\"#\" class=\"text-white/40 hover:text-emerald-400 transition-all duration-300 text-[10px] font-black tracking-[0.4em] uppercase group flex items-center gap-2\" data-kid=\"38\">\n            <span class=\"w-1.5 h-1.5 bg-emerald-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"39\"></span>\n            LinkedIn\n        </a>\n        <a href=\"#\" class=\"text-white/40 hover:text-emerald-400 transition-all duration-300 text-[10px] font-black tracking-[0.4em] uppercase group flex items-center gap-2\" data-kid=\"40\">\n            <span class=\"w-1.5 h-1.5 bg-emerald-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"41\"></span>\n            Dribbble\n        </a>\n    </div>\n</section>\n",
